# Jarvis Unified v3.3 - Complete Configuration
# 100% FREE - Gemini 3.1 Flash Lite + Gemma 4 Code Brain

# ==================== AI CONFIGURATION ====================
# DEFAULT: Gemini 3.1 Flash Lite (15 RPM FREE!)
AI_PROVIDER=gemini

# Get free API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Available models (change to switch):
GEMINI_MODEL=gemini-3.1-flash-lite
# Options:
#   gemini-3.1-flash-lite (DEFAULT - fastest, 15 RPM)
#   gemini-2.0-flash (balanced)
#   gemini-2.0-flash-lite (most economical)
#   gemma-4-9b-it (🧠 CODE BRAIN - powerful)
#   gemma-4-2b-it (🧠 CODE BRAIN - fast)

# ==================== CODE BRAIN (Gemma 4) ====================
# Auto-uses Gemma 4 for code questions
USE_GEMMA_FOR_CODE=true
GEMMA_4_CODE_BRAIN=gemma-4-9b-it

# ==================== SECURITY CONFIRMATIONS ====================
# All set to true for security - Jarvis asks before sensitive actions
CONFIRM_PAYMENTS=true
CONFIRM_ORDERS=true
CONFIRM_SMS=true
CONFIRM_WHATSAPP=true

# ==================== WHATSAPP ====================
# Configure in App Settings (browser UI) or here
WHATSAPP_ENABLED=false
# Option 1: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Option 2: WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ==================== GOOGLE SERVICES ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ==================== UI THEME ====================
UI_THEME=tron
ACCENT_COLOR=#00ffff

# ==================== VOICE ====================
INPUT_MODE=text
TTS_ENGINE=pyttsx3

# ==================== TONE ====================
JARVIS_TONE=helpful

# ==================== LEARNING ====================
SELF_LEARNING=true

# ==================== MEMORY ====================
MEMORY_DB=jarvis_memory.db

# ==================== SERVER ====================
PORT=5000
HOST=0.0.0.0