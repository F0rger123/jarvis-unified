# Jarvis Unified - Environment Configuration
# Copy this to .env and fill in your values

# ==================== AI PROVIDERS ====================
# Priority: OLLAMA (free/local) > OPENROUTER (free tier) > GEMINI (free tier)

# --- Ollama (100% FREE - local) ---
# Install: https://ollama.com
# Run: ollama serve
# Models: qwen3:8b, llama3.2:3b, mistral:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# --- OpenRouter (some free models) ---
# Get key: https://openrouter.ai/keys
# Free model: mistralai/mistral-7b-instruct:free
OPENROUTER_API_KEY=

# --- Google Gemini (free tier) ---
# Get key: https://aistudio.google.com/apikey
# 15 requests/minute free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (optional) ---
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Anthropic Claude (optional) ---
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=


# ==================== GOOGLE SERVICES ====================
# For Gmail and Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth tokens will be stored after first auth


# ==================== VOICE SETTINGS ====================
# TTS Engine: pyttsx3 (free/offline), gtts (free/online), elevenlabs (paid)
TTS_ENGINE=pyttsx3

# STT Engine: whisper (local), google (online)
STT_ENGINE=whisper

# ElevenLabs (optional - premium TTS)
ELEVENLABS_API_KEY=

# Wake word detection (from isair/jarvis)
WAKE_WORD=false
WAKE_WORD_MODEL=jarvis


# ==================== MEMORY ====================
# SQLite database for persistent memory
MEMORY_DB=jarvis_memory.db


# ==================== SERVER SETTINGS ====================
PORT=5000
HOST=0.0.0.0


# ==================== MCP TOOLS (optional) ====================
# MCP_SERVER_URL=


# ==================== REMOTE CONTROL ====================
# WebSocket server for phone/remote control
REMOTE_ENABLED=false
REMOTE_PORT=8765