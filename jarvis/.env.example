# Jarvis Unified v3.3 - Multi-Model Configuration
# Google Gemini 3.1 Flash Lite default + Gemma 4 Code Brain + Model Switching

# ==================== AI - DEFAULT: GEMINI 3.1 FLASH LITE ====================
# Best free tier - 15 RPM, fast!
AI_PROVIDER=gemini

# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === DEFAULT MODEL: Gemini 3.1 Flash Lite ===
GEMINI_MODEL=gemini-3.1-flash-lite

# === AVAILABLE SWITCHABLE MODELS ===
# Just change the line above to any of these:

# 🧠 CODE BRAIN MODELS (automatically used for code tasks)
#USE_GEMMA_FOR_CODE=true
#GEMMA_4_CODE_BRAIN=gemma-4-9b-it  # 9B - more powerful for complex code
#GEMMA_4_CODE_BRAIN=gemma-4-2b-it   # 2B - faster for simple code

# Other free Gemini models:
# GEMINI_MODEL=gemini-2.0-flash          # Balanced
# GEMINI_MODEL=gemini-2.0-flash-lite     # Most economical

# === FALLBACK: OpenRouter (some free models) ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# === FALLBACK: Ollama (local, 100% private) ===
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ==================== CODE BRAIN SETTINGS ====================
# Use Gemma 4 for code tasks automatically?
USE_GEMMA_FOR_CODE=true

# ==================== UI ====================
UI_THEME=tron
ACCENT_COLOR=#00ffff

# ==================== VOICE ====================
INPUT_MODE=text

# ==================== TONE ====================
JARVIS_TONE=helpful

# ==================== WHATSAPP ====================
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
CONFIRM_WHATSAPP=true

# ==================== SECURITY ====================
CONFIRM_PAYMENTS=true

# ==================== SERVER ====================
PORT=5000