# Jarvis Unified v2 - Complete Configuration
# 100% FREE - No paid APIs required
# Copy this to .env and configure

# ==================== AI PROVIDERS ====================
# Priority: OLLAMA (free local) > OPENROUTER (free tier) > GEMINI (free tier)

# === FREE Local AI (RECOMMENDED) ===
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# Install: https://ollama.com
# Run: ollama serve
# Then: ollama pull qwen3:8b

# === Free API Tier (Optional) ===
# OpenRouter - some free models
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini - 15 RPM free
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ==================== VOICE SETTINGS ====================
# TTS (Text-to-Speech) - pyttsx3 is FREE and offline
TTS_ENGINE=pyttsx3
# Options: pyttsx3 (free/offline), gtts (free/online), elevenlabs (paid)

# STT (Speech-to-Text) - whisper is FREE and local
STT_ENGINE=whisper
# Options: whisper (local/free), google (online)

# ElevenLabs - Optional premium TTS
ELEVENLABS_API_KEY=

# Wake Word
WAKE_WORD=Jarvis
# Custom wake commands (comma-separated)
CUSTOM_WAKE_COMMANDS=Hey Jarvis,Computer,Assistant

# ==================== AUDIO/VIDEO INPUT ====================
# Device selection (use 'default' or device name)
MICROPHONE=default
HEADSET=default
CAMERA=default
# Note: UI will show available devices to choose from

# ==================== TONE & PERSONALITY ====================
JARVIS_TONE=helpful
# Options: helpful, humorous, sassy, formal, friendly, minimal
# humorous: adds jokes and fun
# sassy: direct and witty
# formal: professional and precise
# friendly: warm and conversational

JARVIS_NAME=Jarvis
# What to call your assistant

# ==================== SCREEN SHARING ====================
SCREEN_SHARE=false
# Toggle in UI - only on demand

# ==================== LEARNING & MEMORY ====================
MEMORY_DB=jarvis_memory.db
LEARN_PREFERENCES=true
LEARN_GESTURES=true
# Jarvis will learn your preferences and hand gestures

# ==================== GOOGLE SERVICES ====================
# Get credentials from: https://console.cloud.google.com
# Enable: Gmail API, Google Calendar API, Google Drive API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Get refresh token via OAuth flow (see SETUP.md)
GOOGLE_REFRESH_TOKEN=

# ==================== BROWSER CONTROL ====================
DEFAULT_BROWSER=chrome
# Options: chrome, edge, firefox, default

# Browser paths (if not in PATH)
CHROME_PATH=
EDGE_PATH=

# ==================== AUTOMATION ====================
AUTO_EMAILS=false
# Enable automated emails
EMAIL_SCHEDULE=07:00,19:00
# Times to send daily summaries (comma-separated, 24hr format)

# GitHub integration
GITHUB_REPO=username/repo
GITHUB_TOKEN=

# ==================== UI SETTINGS ====================
PORT=5000

# Theme: dark or light
THEME=dark

# Accent color (hex)
ACCENT_COLOR=#3b82f6

# Show speech visually in UI
SHOW_SPEECH_VISUAL=true

# ==================== REMOTE CONTROL ====================
REMOTE_ENABLED=false
REMOTE_PORT=8765
# Control Jarvis from phone on same network