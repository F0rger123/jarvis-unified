# Jarvis Unified v3.1 - Gemini + WhatsApp Configuration
# 100% FREE - Works on any device with internet
# Copy to .env and configure

# ==================== AI - GEMINI (FREE TIER!) ====================
# Priority: Gemini (free 15/min) > Ollama (local) > OpenRouter
AI_PROVIDER=gemini

# Google Gemini - FREE TIER (15 requests/minute!)
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Fallback: Ollama (local, optional)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Fallback: OpenRouter (some free models)
OPENROUTER_API_KEY=

# ==================== WHATSAPP ====================
WHATSAPP_ENABLED=false

# Option 1: WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=

# Option 2: Twilio (alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Security - Always confirm WhatsApp
CONFIRM_WHATSAPP=true

# ==================== UI ====================
UI_THEME=tron
ACCENT_COLOR=#00ffff

# ==================== VOICE ====================
INPUT_MODE=text
TTS_ENGINE=pyttsx3

# ==================== TONE ====================
JARVIS_TONE=helpful

# ==================== LEARNING ====================
SELF_LEARNING=true

# ==================== SECURITY ====================
CONFIRM_PAYMENTS=true
CONFIRM_ORDERS=true
CONFIRM_SMS=true

# ==================== GOOGLE SERVICES (Optional) ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ==================== SERVER ====================
PORT=5000