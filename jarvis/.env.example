# Jarvis Unified v3 - Complete Configuration
# 100% FREE - Tron UI + Food Agent + Self-Learning + SMS
# Copy this to .env and configure

# ==================== AI - 100% FREE ====================
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Optional: Free API fallback
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ==================== UI - TRON STYLE ====================
UI_THEME=tron
ACCENT_COLOR=#00ffff
SECONDARY_COLOR=#ff00ff
GRID_COLOR=#00ffff33

# ==================== VOICE & INPUT ====================
TTS_ENGINE=pyttsx3
STT_ENGINE=whisper
WAKE_WORD=Jarvis
INPUT_MODE=text  # text or voice

# ==================== TONE ====================
JARVIS_TONE=helpful
# Options: helpful, humorous, sassy, formal, friendly

# ==================== SELF-LEARNING ====================
SELF_LEARNING=true
LEARNING_DB=jarvis_learning.json

# ==================== MEMORY & BRAIN VIZ ====================
MEMORY_DB=jarvis_memory.db
BRAIN_VIZ=true

# ==================== FOOD AGENT ====================
FOOD_DEFAULT_STORE=walmart
# Options: walmart, instacart, doordash (API integration needed)

# ==================== SMS VIA GMAIL ====================
SMS_VIA_GMAIL=true
# Send SMS through Gmail carrier gateways (FREE)

# ==================== SECURITY ====================
CONFIRM_PAYMENTS=true
CONFIRM_ORDERS=true
CONFIRM_SMS=true
# ALWAYS confirm before payments, orders, or SMS

# ==================== DASHBOARD ====================
DASHBOARD=true

# ==================== GOOGLE SERVICES ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ==================== SERVER ====================
PORT=5000